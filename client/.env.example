# Firebase Web app config (see README step 2). These are safe to expose in the
# browser bundle, but keep them out of git anyway. All keys are prefixed VITE_
# so Vite will expose them to the client.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Base URL of the backend API. Leave blank for local dev (Vite proxies /api).
# In production set this to your Render backend URL, e.g. https://sua-api.onrender.com
VITE_API_BASE_URL=

# Restrict Google sign-in to a school domain (optional), e.g. yourschool.org
VITE_ALLOWED_EMAIL_DOMAIN=

# When true the app shows demo login buttons and uses demo tokens (no Firebase).
VITE_DEMO_MODE=true
